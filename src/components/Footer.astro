---
const year = new Date().getFullYear();
---

<footer>
	<div class="footer-inner">
		<p>&copy; {year} FeiYan. Built with <a href="https://astro.build" target="_blank">Astro</a></p>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border-light);
		margin-top: 4rem;
	}

	.footer-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 2rem 1.5rem;
		text-align: center;
	}

	p {
		margin: 0;
		color: var(--text-muted);
		font-size: 0.85rem;
	}

	a {
		color: var(--text-secondary);
	}
</style>
