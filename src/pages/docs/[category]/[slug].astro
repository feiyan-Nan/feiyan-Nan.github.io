---
import { getCollection, render } from 'astro:content';
import BackToTop from '../../../components/BackToTop.astro';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import TableOfContents from '../../../components/TableOfContents.astro';
import { SITE_TITLE } from '../../../consts';
import { CATEGORIES } from '../../../data/categories';

export async function getStaticPaths() {
	const docs = await getCollection('docs');
	return docs.map((doc) => {
		const slug = doc.id.split('/').pop()!;
		return {
			params: { category: doc.data.category, slug },
			props: { doc },
		};
	});
}

const { doc } = Astro.props;
const { Content } = await render(doc);
const catInfo = CATEGORIES.find((c) => c.slug === doc.data.category)!;

const allDocs = await getCollection('docs');
const siblingDocs = allDocs
	.filter((d) => d.data.category === doc.data.category)
	.sort((a, b) => a.data.order - b.data.order);

const currentIndex = siblingDocs.findIndex((d) => d.id === doc.id);
const prevDoc = currentIndex > 0 ? siblingDocs[currentIndex - 1] : null;
const nextDoc = currentIndex < siblingDocs.length - 1 ? siblingDocs[currentIndex + 1] : null;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${doc.data.title} - ${SITE_TITLE}`} description={`${catInfo.name} - ${doc.data.title}`} />
	</head>
	<body>
		<Header />
		<div class="layout">
			<aside class="sidebar">
				<a href={`/docs/${doc.data.category}`} class="sidebar-title">
					<span>{catInfo.icon}</span>
					<span>{catInfo.name}</span>
				</a>
				<nav class="sidebar-nav">
					{siblingDocs.map((d) => (
						<a
							href={`/docs/${d.data.category}/${d.id.split('/').pop()}`}
							class:list={['sidebar-link', { active: d.id === doc.id }]}
						>
							{d.data.title}
						</a>
					))}
				</nav>
			</aside>
			<main>
				<div class="breadcrumb">
					<a href="/docs">笔记</a>
					<span class="sep">/</span>
					<a href={`/docs/${doc.data.category}`}>{catInfo.name}</a>
					<span class="sep">/</span>
					<span class="current">{doc.data.title}</span>
				</div>
				<article class="prose">
					<h1>{doc.data.title}</h1>
					<Content />
				</article>
				<nav class="pagination">
					{prevDoc ? (
						<a href={`/docs/${prevDoc.data.category}/${prevDoc.id.split('/').pop()}`} class="prev">
							<span class="label">&larr; 上一篇</span>
							<span class="title">{prevDoc.data.title}</span>
						</a>
					) : <div />}
					{nextDoc ? (
						<a href={`/docs/${nextDoc.data.category}/${nextDoc.id.split('/').pop()}`} class="next">
							<span class="label">下一篇 &rarr;</span>
							<span class="title">{nextDoc.data.title}</span>
						</a>
					) : <div />}
				</nav>
			</main>
			<TableOfContents />
		</div>
		<BackToTop />
		<Footer />
	</body>
</html>

<style>
	.layout {
		max-width: var(--max-width);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 240px 1fr 180px;
		gap: 1.5rem;
		padding: 0 1.5rem;
	}

	.sidebar {
		position: sticky;
		top: 80px;
		height: calc(100vh - 96px);
		overflow-y: auto;
		padding: 1.5rem 0;
		border-right: 1px solid var(--border-light);
	}

	.sidebar::-webkit-scrollbar {
		width: 4px;
	}

	.sidebar::-webkit-scrollbar-thumb {
		background: var(--border);
		border-radius: 2px;
	}

	.sidebar-title {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--text);
		padding: 0.5rem 0.75rem;
		margin-bottom: 0.5rem;
		border-radius: var(--radius-sm);
	}

	.sidebar-title:hover {
		color: var(--accent);
		background: var(--bg-muted);
	}

	.sidebar-nav {
		display: flex;
		flex-direction: column;
		gap: 1px;
	}

	.sidebar-link {
		display: block;
		padding: 0.4rem 0.75rem;
		font-size: 0.82rem;
		color: var(--text-secondary);
		border-radius: 6px;
		line-height: 1.4;
		transition: all 0.15s;
	}

	.sidebar-link:hover {
		color: var(--accent);
		background: var(--bg-muted);
	}

	.sidebar-link.active {
		color: var(--accent);
		background: var(--accent-bg);
		font-weight: 600;
	}

	main {
		min-width: 0;
		padding: 1.5rem 0 3rem;
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		font-size: 0.82rem;
		margin-bottom: 1.5rem;
		flex-wrap: wrap;
	}

	.breadcrumb a {
		color: var(--text-muted);
	}

	.breadcrumb a:hover {
		color: var(--accent);
	}

	.breadcrumb .sep {
		color: var(--border);
	}

	.breadcrumb .current {
		color: var(--text-secondary);
	}

	.prose {
		max-width: 780px;
	}

	.prose h1 {
		font-size: 2rem;
		font-weight: 800;
		margin-bottom: 2rem;
		padding-bottom: 1rem;
		border-bottom: 2px solid var(--border);
	}

	.prose :global(h2) {
		font-size: 1.5rem;
		font-weight: 700;
		margin: 2.5rem 0 1rem;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid var(--border-light);
	}

	.prose :global(h3) {
		font-size: 1.2rem;
		font-weight: 650;
		margin: 2rem 0 0.75rem;
	}

	.prose :global(h4) {
		font-size: 1.05rem;
		font-weight: 600;
		margin: 1.5rem 0 0.5rem;
	}

	.prose :global(p) {
		margin: 0 0 1.25em;
		line-height: 1.8;
	}

	.prose :global(ul),
	.prose :global(ol) {
		margin: 0 0 1.25em;
		padding-left: 1.5em;
	}

	.prose :global(li) {
		margin: 0.375em 0;
		line-height: 1.7;
	}

	.prose :global(img) {
		border-radius: var(--radius-sm);
		border: 1px solid var(--border);
		margin: 1em 0;
	}

	.prose :global(pre) {
		margin: 1.5em 0;
	}

	.pagination {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.pagination a {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
		padding: 1rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-sm);
		transition: all 0.15s;
	}

	.pagination a:hover {
		border-color: var(--accent-light);
		background: var(--accent-bg);
	}

	.pagination .next {
		text-align: right;
	}

	.pagination .label {
		font-size: 0.78rem;
		color: var(--text-muted);
	}

	.pagination .title {
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--accent);
	}

	@media (max-width: 1100px) {
		.layout {
			grid-template-columns: 240px 1fr;
		}
	}

	@media (max-width: 860px) {
		.layout {
			grid-template-columns: 1fr;
		}

		.sidebar {
			position: static;
			height: auto;
			border-right: none;
			border-bottom: 1px solid var(--border-light);
			padding: 1rem 0;
		}

		.sidebar-nav {
			max-height: 200px;
			overflow-y: auto;
		}
	}

	@media (max-width: 640px) {
		.pagination {
			grid-template-columns: 1fr;
		}
	}
</style>
