<rect x="0" y="0" width="500" height="36" rx="12" fill="#f1f5f9"/>
<rect x="0" y="24" width="500" height="12" fill="#f1f5f9"/>
<circle cx="18" cy="18" r="5" fill="#ef4444" opacity="0.7"/>
<circle cx="36" cy="18" r="5" fill="#eab308" opacity="0.7"/>
<circle cx="54" cy="18" r="5" fill="#22c55e" opacity="0.7"/>
<text x="250" y="22" text-anchor="middle" font-size="12" fill="#64748b">DevTools Console</text>
<text x="250" y="76" text-anchor="middle" font-size="14" fill="#475569">dir(obj) — 以对象树形式展示</text>
<text x="250" y="100" text-anchor="middle" font-size="14" fill="#475569">keys(obj) — 返回对象所有 key</text>
