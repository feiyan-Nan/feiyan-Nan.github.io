<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 180" width="500" height="180">
<style>text { font-family: system-ui, -apple-system, sans-serif; }</style>
<rect x="0" y="0" width="500" height="180" rx="12" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1"/><rect x="0" y="0" width="500" height="36" rx="12" fill="#f1f5f9"/><rect x="0" y="24" width="500" height="12" fill="#f1f5f9"/><circle cx="18" cy="18" r="5" fill="#ef4444" opacity="0.7"/><circle cx="36" cy="18" r="5" fill="#eab308" opacity="0.7"/><circle cx="54" cy="18" r="5" fill="#22c55e" opacity="0.7"/><text x="250" y="22" text-anchor="middle" font-size="12" fill="#64748b" font-family="system-ui">DevTools - monitor()</text><text x="250" y="70" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui">monitor(functionName)</text><text x="250" y="92" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui">监听函数调用，输出参数信息</text><text x="250" y="114" text-anchor="middle" font-size="14" fill="#475569" font-family="system-ui">unmonitor(fn) 停止监听</text>
