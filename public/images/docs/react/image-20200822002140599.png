<defs><marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto"><polygon points="0 0, 10 3.5, 0 7" fill="#64748b"/></marker></defs><text x="375" y="28" font-size="20" font-weight="700" fill="#1e293b" font-family="system-ui, sans-serif" text-anchor="middle">React 组件生命周期</text><rect x="20" y="45" width="220" height="30" rx="6" fill="#dbeafe"/><text x="130" y="65" text-anchor="middle" font-size="13" font-weight="600" fill="#2563eb" font-family="system-ui">挂载 Mounting</text><rect x="260" y="45" width="220" height="30" rx="6" fill="#d1fae5"/><text x="370" y="65" text-anchor="middle" font-size="13" font-weight="600" fill="#059669" font-family="system-ui">更新 Updating</text><rect x="500" y="45" width="220" height="30" rx="6" fill="#fef2f2"/><text x="610" y="65" text-anchor="middle" font-size="13" font-weight="600" fill="#dc2626" font-family="system-ui">卸载 Unmounting</text><rect x="30" y="90" width="200" height="38" rx="8" fill="#eef2ff" stroke="#6366f1" stroke-width="1.5"/><text x="130" y="109" text-anchor="middle" font-size="11" fill="#1e293b" font-family="system-ui, sans-serif">constructor()</text><line x1="130" y1="128" x2="130" y2="142" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#arrowhead)"/><rect x="30" y="142" width="200" height="38" rx="8" fill="#eef2ff" stroke="#6366f1" stroke-width="1.5"/><text x="130" y="161" text-anchor="middle" font-size="11" fill="#1e293b" font-family="system-ui, sans-serif">getDerivedStateFromProps()</text><line x1="130" y1="180" x2="130" y2="194" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#arrowhead)"/><rect x="30" y="194" width="200" height="38" rx="8" fill="#eef2ff" stroke="#6366f1" stroke-width="1.5"/><text x="130" y="213" text-anchor="middle" font-size="11" fill="#1e293b" font-family="system-ui, sans-serif">render()</text><line x1="130" y1="232" x2="130" y2="246" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#arrowhead)"/><rect x="30" y="246" width="200" height="38" rx="8" fill="#e